<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.DashboardController"
            prefWidth="1280" prefHeight="800">

    <!-- ============ HEADER (Shopee gradient) ============ -->
    <top>
        <VBox>
            <HBox styleClass="header-shopee" alignment="CENTER_LEFT" spacing="16">
                <Label text="🔨 BidNow" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="0">
                    <TextField fx:id="searchField" styleClass="header-search-shopee" HBox.hgrow="ALWAYS"
                               promptText="Tìm kiếm phiên đấu giá, sản phẩm, người bán…"/>
                    <Button text="🔍  TÌM" styleClass="header-search-btn"/>
                </HBox>

                <Button text="🔔" styleClass="header-cart-btn" onAction="#handleNotifications"/>
                <Button text="🛒" styleClass="header-cart-btn" onAction="#handleWatchlist"/>
                <Button text="+ Đăng" styleClass="header-cart-btn" onAction="#handleCreateItem"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label fx:id="avatarLabel" text="N" styleClass="avatar-circle"
                           style="-fx-background-color: white; -fx-text-fill: -fx-primary;"/>
                    <VBox spacing="0">
                        <Label fx:id="userNameLabel" text="nam_dev" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="Bidder" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 11;"/>
                    </VBox>
                </HBox>
                <Button text="⏻" styleClass="header-cart-btn" onAction="#handleLogout"/>
            </HBox>

            <!-- Quick search keywords -->
            <HBox styleClass="header-shopee" alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #166FE5; -fx-padding: 6 24 8 24;">
                <Label text="Đang HOT:" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 12;"/>
                <Hyperlink text="Macbook M3" style="-fx-text-fill: white; -fx-font-size: 12;"/>
                <Hyperlink text="iPhone 15" style="-fx-text-fill: white; -fx-font-size: 12;"/>
                <Hyperlink text="Rolex"     style="-fx-text-fill: white; -fx-font-size: 12;"/>
                <Hyperlink text="Honda Civic" style="-fx-text-fill: white; -fx-font-size: 12;"/>
                <Hyperlink text="Tranh sơn dầu" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: -fx-bg; -fx-background: -fx-bg;">
            <VBox spacing="20">
                <padding><Insets top="20" right="40" bottom="24" left="40"/></padding>

                <!-- ============ HERO BANNER ============ -->
                <HBox spacing="14">
                    <StackPane styleClass="hero-banner" HBox.hgrow="ALWAYS" prefHeight="240">
                        <VBox alignment="CENTER_LEFT" spacing="12">
                            <padding><Insets left="40"/></padding>
                            <Label text="ĐẤU GIÁ TUẦN VÀNG" styleClass="hero-text-sub"
                                   style="-fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14;"/>
                            <Label text="Macbook M3 - Giá khởi điểm 0₫" styleClass="hero-text-big" wrapText="true"/>
                            <Label text="3 ngày, 50+ phiên, hàng chính hãng có hóa đơn." styleClass="hero-text-sub"/>
                            <Button text="🔥  THAM GIA NGAY" styleClass="hero-cta"/>
                        </VBox>
                        <HBox alignment="BOTTOM_CENTER" spacing="6" StackPane.alignment="BOTTOM_CENTER">
                            <StackPane.margin><Insets bottom="14"/></StackPane.margin>
                            <Region styleClass="dot-indicator,dot-indicator-active"/>
                            <Region styleClass="dot-indicator"/>
                            <Region styleClass="dot-indicator"/>
                        </HBox>
                    </StackPane>

                    <VBox spacing="14" prefWidth="280">
                        <StackPane prefHeight="113"
                                   style="-fx-background-color: linear-gradient(135deg, #FA383E, #FF7A00); -fx-background-radius: 12;">
                            <VBox alignment="CENTER_LEFT" spacing="4">
                                <padding><Insets left="20"/></padding>
                                <Label text="⚡ FLASH AUCTION" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                                <Label text="Kết thúc trong" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 11;"/>
                                <Label text="01:23:45" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22;"/>
                            </VBox>
                        </StackPane>
                        <StackPane prefHeight="113"
                                   style="-fx-background-color: linear-gradient(135deg, #42B72A, #009A66); -fx-background-radius: 12;">
                            <VBox alignment="CENTER_LEFT" spacing="4">
                                <padding><Insets left="20"/></padding>
                                <Label text="🎁 NEWBIE DEAL" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
                                <Label text="Người mới đăng ký" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 11;"/>
                                <Label text="Giảm phí giao dịch" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16;"/>
                            </VBox>
                        </StackPane>
                    </VBox>
                </HBox>

                <!-- ============ CATEGORY STRIP ============ -->
                <VBox styleClass="card,card-padded" spacing="14">
                    <Label text="DANH MỤC" styleClass="h3"/>
                    <HBox spacing="20" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="6"><Label text="📱" styleClass="category-icon"/><Label text="Điện tử" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="🎨" styleClass="category-icon"/><Label text="Nghệ thuật" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="🚗" styleClass="category-icon"/><Label text="Xe cộ" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="💎" styleClass="category-icon"/><Label text="Trang sức" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="⌚" styleClass="category-icon"/><Label text="Đồng hồ" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="📷" styleClass="category-icon"/><Label text="Máy ảnh" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="📚" styleClass="category-icon"/><Label text="Sách" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="🏺" styleClass="category-icon"/><Label text="Cổ vật" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="🎮" styleClass="category-icon"/><Label text="Game" styleClass="category-label"/></VBox>
                        <VBox alignment="CENTER" spacing="6"><Label text="⋯" styleClass="category-icon"/><Label text="Tất cả" styleClass="category-label"/></VBox>
                    </HBox>
                </VBox>

                <!-- ============ FLASH AUCTION BAND ============ -->
                <VBox spacing="0">
                    <HBox styleClass="flash-band" alignment="CENTER_LEFT" spacing="14">
                        <Label text="⚡" style="-fx-font-size: 26; -fx-text-fill: white;"/>
                        <Label text="FLASH AUCTION" styleClass="flash-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Kết thúc:" style="-fx-text-fill: white; -fx-font-size: 12;"/>
                        <Label text="01" styleClass="flash-timer-block"/>
                        <Label text=":" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="23" styleClass="flash-timer-block"/>
                        <Label text=":" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="45" styleClass="flash-timer-block"/>
                        <Hyperlink text="Xem tất cả  ›" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                    <HBox styleClass="flash-body" spacing="14" fx:id="flashRow"/>
                </VBox>

                <!-- ============ ĐỀ XUẤT CHO BẠN ============ -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="✨ ĐỀ XUẤT CHO BẠN" styleClass="h2"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="sortBox" promptText="Sắp xếp" prefWidth="180"/>
                </HBox>
                <FlowPane fx:id="auctionGrid" hgap="14" vgap="14"/>

                <!-- TableView (giữ Task 2.5 - Tuần 7 yêu cầu) -->
                <Label text="📋 Tất cả phiên đấu giá" styleClass="h2"/>
                <VBox styleClass="card">
                    <TableView fx:id="auctionTable" prefHeight="280">
                        <columns>
                            <TableColumn fx:id="colName"   text="Sản phẩm"     prefWidth="240"/>
                            <TableColumn fx:id="colCat"    text="Danh mục"     prefWidth="120"/>
                            <TableColumn fx:id="colSeller" text="Người bán"    prefWidth="140"/>
                            <TableColumn fx:id="colBid"    text="Giá hiện tại" prefWidth="160"/>
                            <TableColumn fx:id="colTime"   text="Còn lại"      prefWidth="120"/>
                            <TableColumn fx:id="colStatus" text="Trạng thái"   prefWidth="120"/>
                        </columns>
                        <placeholder><Label text="Chưa có phiên nào." styleClass="muted"/></placeholder>
                    </TableView>
                </VBox>

                <Region prefHeight="20"/>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ============ BOTTOM NAV (Shopee mobile feel) ============ -->
    <bottom>
        <HBox styleClass="bottom-nav" alignment="CENTER" spacing="40">
            <Button text="Trang chủ"  graphic-text-gap="2" styleClass="bottom-nav-item,bottom-nav-item-active" onAction="#handleNavHome">
                <graphic><Label text="🏠" style="-fx-font-size: 22;"/></graphic>
            </Button>
            <Button text="Live"       styleClass="bottom-nav-item" onAction="#handleNavLive">
                <graphic><Label text="🟢" style="-fx-font-size: 22;"/></graphic>
            </Button>
            <Button text="Theo dõi"   styleClass="bottom-nav-item" onAction="#handleWatchlist">
                <graphic><Label text="🛒" style="-fx-font-size: 22;"/></graphic>
            </Button>
            <Button text="Đấu giá"    styleClass="bottom-nav-item" onAction="#handleNavMyBids">
                <graphic><Label text="📜" style="-fx-font-size: 22;"/></graphic>
            </Button>
            <Button text="Tài khoản"  styleClass="bottom-nav-item" onAction="#handleNavProfile">
                <graphic><Label text="👤" style="-fx-font-size: 22;"/></graphic>
            </Button>
        </HBox>
    </bottom>
</BorderPane>
