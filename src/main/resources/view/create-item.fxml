<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.CreateItemController"
            prefWidth="1280" prefHeight="800">

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16">
            <Button text="←  Quay lại" styleClass="btn-ghost" onAction="#handleCancel"/>
            <Label text="BidNow" styleClass="navbar-logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="N" styleClass="avatar-circle"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: -fx-bg; -fx-background: -fx-bg;">
            <HBox alignment="TOP_CENTER">
                <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                <VBox spacing="20" prefWidth="720" maxWidth="720">
                    <Label text="Đăng phiên đấu giá mới" styleClass="h1"/>
                    <Label text="Điền đầy đủ thông tin để bắt đầu phiên đấu giá." styleClass="muted"/>

                    <VBox styleClass="card,card-padded" spacing="14">
                        <Label text="Hình ảnh sản phẩm" styleClass="h3"/>
                        <StackPane fx:id="imageDrop" prefHeight="220"
                                   style="-fx-background-color: -fx-primary-light; -fx-background-radius: 12;
                                          -fx-border-color: -fx-primary; -fx-border-style: dashed;
                                          -fx-border-radius: 12; -fx-border-width: 2; -fx-cursor: hand;"
                                   onMouseClicked="#handlePickImage">
                            <VBox alignment="CENTER" spacing="6">
                                <Label text="📷" style="-fx-font-size: 40;"/>
                                <Label text="Click để chọn ảnh hoặc kéo thả vào đây"
                                       style="-fx-font-weight: bold; -fx-text-fill: -fx-primary;"/>
                                <Label text="JPG, PNG tối đa 5MB" styleClass="caption"/>
                            </VBox>
                        </StackPane>
                    </VBox>

                    <VBox styleClass="card,card-padded" spacing="12">
                        <Label text="Thông tin sản phẩm" styleClass="h3"/>

                        <Label text="Tên sản phẩm" styleClass="caption"/>
                        <TextField fx:id="nameField" promptText="VD: MacBook Pro M3 14 inch"/>

                        <HBox spacing="12">
                            <VBox HBox.hgrow="ALWAYS" spacing="4">
                                <Label text="Danh mục" styleClass="caption"/>
                                <ComboBox fx:id="categoryBox" maxWidth="Infinity"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="4">
                                <Label text="Tình trạng" styleClass="caption"/>
                                <ComboBox fx:id="conditionBox" maxWidth="Infinity"/>
                            </VBox>
                        </HBox>

                        <Label text="Mô tả chi tiết" styleClass="caption"/>
                        <TextArea fx:id="descArea" prefRowCount="5"
                                  promptText="Mô tả tình trạng, nguồn gốc, đặc điểm nổi bật của sản phẩm..."/>
                    </VBox>

                    <VBox styleClass="card,card-padded" spacing="12">
                        <Label text="Cấu hình đấu giá" styleClass="h3"/>

                        <HBox spacing="12">
                            <VBox HBox.hgrow="ALWAYS" spacing="4">
                                <Label text="Giá khởi điểm (₫)" styleClass="caption"/>
                                <TextField fx:id="startPriceField" promptText="VD: 5000000"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="4">
                                <Label text="Bước giá (₫)" styleClass="caption"/>
                                <TextField fx:id="stepPriceField" promptText="VD: 500000"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12">
                            <VBox HBox.hgrow="ALWAYS" spacing="4">
                                <Label text="Thời lượng (giờ)" styleClass="caption"/>
                                <ComboBox fx:id="durationBox" maxWidth="Infinity"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="4">
                                <Label text="Giá mua ngay (tùy chọn)" styleClass="caption"/>
                                <TextField fx:id="buyNowField" promptText="VD: 50000000"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <Label fx:id="errorLabel" styleClass="error-text" visible="false" managed="false"/>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Hủy" styleClass="btn-ghost" onAction="#handleCancel"/>
                        <Button text="Lưu nháp" styleClass="btn-secondary" onAction="#handleDraft"/>
                        <Button text="🚀  Đăng phiên đấu giá" styleClass="btn-primary"
                                onAction="#handleSubmit"/>
                    </HBox>

                    <Region prefHeight="20"/>
                </VBox>
            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
